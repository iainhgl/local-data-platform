# Profile selector — controls both Docker Compose services and dbt adapter
# Options: simple | postgres | lakehouse | full
COMPOSE_PROFILES=simple

# DuckDB (simple profile)
# Path to DuckDB database file, relative to repo root
DBT_DUCKDB_PATH=dev.duckdb

# Postgres (postgres profile)
# Host where Postgres is running (use 'localhost' for local Docker)
POSTGRES_HOST=localhost
# Port mapped from Docker container to host (default: 18040)
POSTGRES_PORT=18040
# dbt service account username
POSTGRES_USER=dbt
# dbt service account password — replace with a strong password
POSTGRES_PASSWORD=changeme
# Database name created on first startup
POSTGRES_DB=local_data_platform

# MinIO — object storage (lakehouse profile)
# Root admin username for MinIO console access
MINIO_ROOT_USER=minio
# Root admin password — replace with a strong password
MINIO_ROOT_PASSWORD=changeme
# MinIO S3-compatible API endpoint
MINIO_ENDPOINT=http://localhost:18060

# Trino — distributed query engine (lakehouse profile)
TRINO_HOST=localhost
# Port mapped from Docker container to host (default: 18070)
TRINO_PORT=18070
# Trino username (no authentication in local dev mode)
TRINO_USER=trino

# Lightdash — BI dashboard (all profiles)
# Random secret used to sign Lightdash sessions — generate with: openssl rand -hex 32
LIGHTDASH_SECRET=changeme-generate-a-random-string
# Password for Lightdash's internal Postgres metadata database (not the data warehouse)
LIGHTDASH_DB_PASSWORD=changeme

# Keycloak — SSO and service authentication (full profile)
# Admin username for Keycloak master realm
KEYCLOAK_ADMIN=admin
# Admin password — replace with a strong password
KEYCLOAK_ADMIN_PASSWORD=changeme

# Superset — BI and data exploration (full profile)
# Random secret key — generate with: openssl rand -hex 32
SUPERSET_SECRET_KEY=changeme-generate-a-random-string
