# Environment — NEVER commit .env files
.env
.env.*
!.env.example

# dbt build artifacts
target/
dbt_packages/
logs/
edr_target/

# Python
__pycache__/
*.pyc
*.pyo
.venv/
venv/
*.egg-info/

# Generated data files — recreated by faker_generator.py each run
data/*.json

# DuckDB local database file — recreated by dbt run
*.duckdb
*.duckdb.wal

# Evidence build artifacts
evidence/node_modules/
evidence/.evidence/
evidence/.env
evidence/*.core

# dbt user config — machine-specific, not for version control
.user.yml

# OS
.DS_Store
Thumbs.db
